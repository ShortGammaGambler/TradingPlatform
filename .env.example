# =============================================================================
# Unified Trading Platform - Environment Variables
# Copy to .env and fill in your API keys
# =============================================================================

# --- Schwab API (OAuth2) ---
SCHWAB_APP_KEY=your_schwab_app_key
SCHWAB_APP_SECRET=your_schwab_app_secret
SCHWAB_REDIRECT_URI=https://127.0.0.1
SCHWAB_TOKEN_PATH=./schwab_tokens.json

# --- Polygon.io ---
POLYGON_API_KEY=your_polygon_api_key

# --- SpotGamma ---
SPOTGAMMA_API_KEY=your_spotgamma_api_key
API_GEX_EX_INF=https://your-spotgamma-endpoint/execution-info
API_GEX_ZERO=https://your-spotgamma-endpoint/zero-gamma
API_GEX_PROFILE=https://your-spotgamma-endpoint/gex-profile
API_GEX_STRIKES=https://your-spotgamma-endpoint/gex-strikes
API_GEX_OHLC=https://your-spotgamma-endpoint/ohlc-data

# --- FRED (macro data) ---
FRED_API_KEY=your_fred_api_key

# --- Alpha Vantage ---
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# --- Notifications ---
# Email (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=your_email@gmail.com

# Twilio SMS
TWILIO_SID=your_twilio_sid
TWILIO_TOKEN=your_twilio_token
TWILIO_FROM=+1234567890
SMS_TO=+1234567890

# Discord
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_url

# --- Database ---
DB_PATH=./data/trading.db
JOURNAL_DB_PATH=./data/trade_journal.db

# --- Risk Settings ---
MAX_POSITION_SIZE_PCT=5.0
MAX_PORTFOLIO_HEAT_PCT=20.0
KELLY_FRACTION=0.5

# --- Logging ---
LOG_LEVEL=INFO
